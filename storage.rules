rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsAudit(auditId) {
      return isSignedIn()
        && exists(/databases/(default)/documents/audits/$(auditId))
        && get(/databases/(default)/documents/audits/$(auditId)).data.userId == request.auth.uid;
    }

    match /audits/{auditId}/{allPaths=**} {
      allow read, write: if ownsAudit(auditId);
    }
  }
}
